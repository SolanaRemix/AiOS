# ─────────────────────────────────────────────
# AIOS Platform – Environment Variables Template
# Copy to .env and fill in real values
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Admin bootstrap credentials (used by seed script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ─── Database ────────────────────────────────
# PostgreSQL connection string (supports Supabase / Neon / self-hosted)
DATABASE_URL=postgresql://postgres:password@localhost:5432/aios_dev
# Direct connection for Prisma migrations (Neon / PgBouncer setups)
DIRECT_URL=postgresql://postgres:password@localhost:5432/aios_dev

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string
JWT_REFRESH_SECRET=replace-with-another-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (AES-256 for stored secrets) ─
ENCRYPTION_KEY=replace-with-32-char-hex-key

# ─── OpenAI ──────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# ─── Anthropic ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Gemini ───────────────────────────
GOOGLE_GEMINI_API_KEY=AIza...

# ─── Azure OpenAI ────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# ─── Ollama (local models) ───────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── Stripe ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Email / SMTP ────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@aios.app

# ─── Docker ──────────────────────────────────
DOCKER_REGISTRY=ghcr.io/your-org/aios
DOCKER_TAG=latest

# ─── Logging ─────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
