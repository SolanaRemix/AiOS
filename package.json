{
  "name": "aios-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*", "core"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:seed": "cd apps/api && npm run db:seed",
    "db:generate": "npm run db:generate --workspace=apps/api"
  },
  "devDependencies": {
    "turbo": "^1.13.3",
    "typescript": "^5.3.3",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
